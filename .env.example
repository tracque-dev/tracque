# Frontend (Vite) — also add these to Vercel env vars
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Function Secrets
# Run: supabase secrets set KEY=value
#
# supabase secrets set OPENAI_API_KEY=sk-...
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# supabase secrets set PERPLEXITY_API_KEY=pplx-...
# supabase secrets set GOOGLE_AI_API_KEY=...
# supabase secrets set SERPAPI_KEY=...
# supabase secrets set QSTASH_TOKEN=...
# supabase secrets set QSTASH_URL=https://qstash.upstash.io/v2/publish/
#
# Frontend scaler (managed browser farm):
# supabase secrets set BROWSERBASE_API_KEY=bb_...
# supabase secrets set BROWSERBASE_PROJECT_ID=...
# supabase secrets set FRONTEND_RUNS=1   # captures per task (optional, default 1)
